# ─────────────────────────────────────────────────
# Pi Butler 配置文件
# 复制此文件为 .env 并填写你的配置：
#   cp .env.example .env
# ─────────────────────────────────────────────────

# ── LLM 配置（推荐：国内 OpenAI 兼容 API）────────────
#
# Pi Butler 建议统一走 OpenAI 兼容模式：
#   PI_BUTLER_PROVIDER=openai
#   OPENAI_BASE_URL=<厂商 base url>
#   OPENAI_API_KEY=<厂商 key>
#   PI_BUTLER_MODEL=<厂商模型名>
#
# 也支持兼容别名（会自动桥接到 OPENAI_*）：
#   OPENAI_COMPAT_API_KEY=<厂商 key>
#   OPENAI_COMPAT_BASE_URL=<厂商 base url>
#   OPENAI_COMPAT_MODEL=<厂商模型名>
#
# 下面 4 组任选其一启用（取消注释即可）：

# [A] 阿里云千问（DashScope 兼容模式）
# PI_BUTLER_PROVIDER=openai
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_API_KEY=sk-xxxx
# PI_BUTLER_MODEL=qwen-plus
# 或使用：DASHSCOPE_API_KEY / QWEN_API_KEY（自动桥接）

# [B] 字节豆包（火山方舟 Ark）
# PI_BUTLER_PROVIDER=openai
# OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# OPENAI_API_KEY=ark-xxxx
# PI_BUTLER_MODEL=doubao-1.5-pro-32k-250115
# 或使用：ARK_API_KEY / DOUBAO_API_KEY（自动桥接）

# [C] Kimi（Moonshot）
# PI_BUTLER_PROVIDER=openai
# OPENAI_BASE_URL=https://api.moonshot.cn/v1
# OPENAI_API_KEY=sk-xxxx
# PI_BUTLER_MODEL=moonshot-v1-8k
# 或使用：MOONSHOT_API_KEY / KIMI_API_KEY（自动桥接）

# [D] DeepSeek
# PI_BUTLER_PROVIDER=openai
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_API_KEY=sk-xxxx
# PI_BUTLER_MODEL=deepseek-chat
# 或使用：DEEPSEEK_API_KEY（自动桥接）

# ── 本地模型（可选）─────────────────────────────────

# Ollama
# PI_BUTLER_PROVIDER=openai
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# PI_BUTLER_MODEL=llama3.2

# LM Studio
# PI_BUTLER_PROVIDER=openai
# OPENAI_BASE_URL=http://localhost:1234/v1
# OPENAI_API_KEY=lm-studio
# PI_BUTLER_MODEL=你加载的模型名

# ── 其他 Provider（可选，非默认推荐）────────────────

# OpenAI 官方
# OPENAI_API_KEY=

# Anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://your-proxy.example.com

# Google Gemini
# GOOGLE_API_KEY=
# GEMINI_API_KEY=     # 与 GOOGLE_API_KEY 等价

# ── OAuth（ChatGPT/Codex 订阅授权，可选）────────────
# 开启后，用户可通过 /api/auth/oauth/start 绑定个人账号。
# 绑定后该用户优先走 OAuth 凭据；未绑定用户继续走 API Key 模式。

# OAuth Provider 端点
# OAUTH_OPENAI_AUTH_URL=
# OAUTH_OPENAI_TOKEN_URL=

# OAuth Client
# OAUTH_OPENAI_CLIENT_ID=
# OAUTH_OPENAI_CLIENT_SECRET=
# OAUTH_OPENAI_REDIRECT_URI=http://localhost:3000/api/auth/oauth/callback
# OAUTH_OPENAI_SCOPE=openid profile offline_access

# OAuth 绑定后使用的模型配置（OpenAI 兼容）
# OAUTH_OPENAI_BASE_URL=https://api.openai.com/v1
# OAUTH_OPENAI_MODEL=gpt-4o

# ── Bot Token（服务模式，不需要可留空）─────────────

# Telegram Bot Token（从 @BotFather 获取）
TELEGRAM_BOT_TOKEN=

# Discord Bot Token（从 Discord Developer Portal 获取）
DISCORD_BOT_TOKEN=

# ── 服务配置（服务模式）────────────────────────────

# HTTP 服务端口（默认 3000）
# PI_BUTLER_PORT=3000

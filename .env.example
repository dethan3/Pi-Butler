# ─────────────────────────────────────────────────
# Pi Butler 配置文件
# 复制此文件为 .env 并填写你的配置：
#   cp .env.example .env
# ─────────────────────────────────────────────────

# ── LLM Provider（至少设置一个）────────────────────

# Anthropic（推荐，使用 Claude Sonnet）
ANTHROPIC_API_KEY=

# OpenAI（使用 GPT-4o）
OPENAI_API_KEY=

# Google（使用 Gemini 2.5 Flash）
GOOGLE_API_KEY=
# GEMINI_API_KEY=     # 与 GOOGLE_API_KEY 等价

# ── 自定义 LLM（可选）──────────────────────────────
# 手动指定 provider 和 model，覆盖自动检测
# PI_BUTLER_PROVIDER=anthropic
# PI_BUTLER_MODEL=claude-sonnet-4-20250514

# OpenAI 兼容自定义端点（如 Ollama、LM Studio、第三方代理）
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama        # Ollama 不需要真实 key，填任意值即可
# PI_BUTLER_PROVIDER=openai
# PI_BUTLER_MODEL=llama3.2      # 替换为你实际加载的模型名

# LM Studio
# OPENAI_BASE_URL=http://localhost:1234/v1
# OPENAI_API_KEY=lm-studio
# PI_BUTLER_PROVIDER=openai
# PI_BUTLER_MODEL=你加载的模型名

# Anthropic 自定义端点（如代理）
# ANTHROPIC_BASE_URL=https://your-proxy.example.com

# ── Bot Token（服务模式，不需要可留空）─────────────

# Telegram Bot Token（从 @BotFather 获取）
TELEGRAM_BOT_TOKEN=

# Discord Bot Token（从 Discord Developer Portal 获取）
DISCORD_BOT_TOKEN=

# ── 服务配置（服务模式）────────────────────────────

# HTTP 服务端口（默认 3000）
# PI_BUTLER_PORT=3000
